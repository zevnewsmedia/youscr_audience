<h1>Broadcast Control Center</h1>

<div>
    <form action="/admin/broadcast-duel-winners" method="GET">
        <label>Event:</label>
        <select name="event_id" onchange="this.form.submit()">
            <option value="">-- Select Event --</option>
            <% events.forEach(e => { %>
                <option value="<%= e._id %>" <%= event_id == e._id.toString() ? 'selected' : '' %>>
                    <%= e.name %>
                </option>
            <% }) %>
        </select>

        <label>Heat:</label>
        <select name="heat" onchange="this.form.submit()">
            <% [1,2,3,4,5].forEach(h => { %>
                <option value="<%= h %>" <%= current_heat == h ? 'selected' : '' %>>Heat <%= h %></option>
            <% }) %>
        </select>
        
        <noscript>
            <button type="submit">Filter</button>
        </noscript>
    </form>
</div>

<% if (matchResults.length > 0) { %>
    <div>
        <h3>Current Standings (Preview)</h3>
        
        <% matchResults.forEach(m => { %>
            <div>
                <strong><%= m.label %></strong><br>
                <span><%= m.display %></span>
            </div>
            <hr>
        <% }) %>

        <div>
            <form action="/admin/broadcast-duel-winners" method="GET">
                <input type="hidden" name="event_id" value="<%= event_id %>">
                <input type="hidden" name="heat" value="<%= current_heat %>">
                <input type="hidden" name="broadcast" value="true">
                
                <button type="submit">
                    📢 SEND TO PUBLIC SCREEN
                </button>
            </form>
            
            <% if (typeof broadcastSent !== 'undefined' && broadcastSent) { %>
                <p>✅ Results successfully broadcasted!</p>
            <% } %>
        </div>
    </div>
<% } else if (event_id) { %>
    <p>No matches found for this selection.</p>
<% } %>