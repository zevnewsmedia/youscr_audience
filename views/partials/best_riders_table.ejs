<table class="admin-table" style="width: 100%; border-collapse: collapse; margin-top: 20px;">
  <thead>
    <tr style="background-color: #f4f4f4; text-align: left;">
      <th style="padding: 10px; border-bottom: 2px solid #ddd;">Rider</th>
      <th style="padding: 10px; border-bottom: 2px solid #ddd;">Heat</th>
      <th style="padding: 10px; border-bottom: 2px solid #ddd;">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (contestants && contestants.length > 0) { %>
      <% contestants.forEach(item => { %>
        <tr>
          <td style="padding: 10px; border-bottom: 1px solid #eee;">
            <%= item.rider_id.name %> <%= item.rider_id.surname %>
          </td>
          <td style="padding: 10px; border-bottom: 1px solid #eee;">
            <%= item.heat %>
          </td>
          <td style="padding: 10px; border-bottom: 1px solid #eee;">
            <button class="btn-remove" onclick="deleteEntry('<%= item._id %>')">Remove</button>
          </td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr>
        <td colspan="3" style="text-align: center; padding: 30px; color: #888;">
          No contestants found for this selection.
        </td>
      </tr>
    <% } %>
  </tbody>
</table>